# ============================================================================
# Caddyfile - Configuration stephaneroos.com
# ============================================================================
# Reverse proxy avec SSL automatique (Let's Encrypt)
# ============================================================================

{
    # TLS is terminated at the Cloudflare edge (the cloudflared tunnel delivers
    # HTTP to Caddy on localhost:80). Disable Caddy's auto-HTTPS entirely: no
    # cert management, no HTTP->HTTPS redirect, no :443 listener.
    auto_https off

    log {
        output file /var/log/caddy/access.log
        format console
    }
}

# ============================================================================
# DOMAINE PRINCIPAL
# ============================================================================

# NOTE: stephaneroos.com (apex) and www are NOT served by Caddy — they are
# CNAME'd to Obsidian Publish (publish-main.obsidian.md). Do not add them to
# the tunnel. Only the subdomains (git, photos, ...) go through Caddy.

# http://www.stephaneroos.com {
#     redir https://stephaneroos.com{uri} permanent
# }

# http://stephaneroos.com {
#     redir https://photos.stephaneroos.com permanent
# }

# ============================================================================
# SERVICES PERSONNELS
# ============================================================================

# Photos (Immich v2.7.5 - merged server+web on host :2283)
http://photos.stephaneroos.com {
    reverse_proxy localhost:2283 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote}
    }
}

# --- Disabled: backing service not ready ------------------------------------
# Nextcloud Personal: cloud-stephaneroos-proxy is in a crash-loop
# (nginx: unknown "nginx_proxy" variable), ports 8081/11001 serve nothing.
# http://cloud.stephaneroos.com {
#     reverse_proxy localhost:11001
# }

# Dashy (home portal): not deployed yet (host :4000 empty).
# http://home.stephaneroos.com {
#     reverse_proxy localhost:4000
# }

# Git (Forgejo, published on host :32768)
http://git.stephaneroos.com {
    reverse_proxy localhost:32768 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote}
    }
}

