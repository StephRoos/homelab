# Immich - Variables d'environnement
# ⚠️ NE JAMAIS COMMITER CE FICHIER DANS GIT
# Copier ce fichier en .env avant utilisation

# ============================================================================
# ⚠️ MOTS DE PASSE À CHANGER (Générer avec des commandes sécurisées)
# ============================================================================

# Mot de passe PostgreSQL pour Immich (min 16 caractères)
# Générer avec : openssl rand -base64 32
IMMICH_DB_PASSWORD=changer_mot_de_passe_postgres_securise_ici

# Clé secrète Immich (obligatoire, 64 caractères hex)
# Générer avec : openssl rand -hex 32
IMMICH_SECRET=changer_cle_secrete_hexadecimale_ici

# ============================================================================
# CONFIGURATION OPTIONNELLE
# ============================================================================

# Timezone (par défaut : Europe/Paris)
# TZ=Europe/Paris

# URL publique (si différent de photos.stephaneroos.com)
# PUBLIC_SERVER_URL=https://photos.stephaneroos.com

# ============================================================================
# EXEMPLE DE GÉNÉRATION DES VALEURS
# ============================================================================
#
# # Dans un terminal, exécuter :
# echo "IMMICH_DB_PASSWORD=$(openssl rand -base64 32)" >> configs/docker/immich.env
# echo "IMMICH_SECRET=$(openssl rand -hex 32)" >> configs/docker/immich.env
# echo "PUBLIC_SERVER_URL=https://photos.stephaneroos.com" >> configs/docker/immich.env
#
# # Puis vérifier le fichier :
# cat configs/docker/immich.env
